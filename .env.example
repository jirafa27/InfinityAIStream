# =============================================================================
# InfinityAIStream — пример конфигурации
# Скопируйте в .env и заполните секреты. Не коммитьте .env в git.
# =============================================================================

COMPOSE_PROJECT_NAME=infinity_stream

# --- Профиль ресурсов: normal (4 CPU / 8 GB) | low (2 CPU / 4 GB) ---
RESOURCE_PROFILE=normal

# --- Docker Compose: лимиты normal (4 vCPU / 8 GB VPS) ---
# CreativeTrace + ОС: ~1–1.5 CPU, ~3 GB RAM
STREAM_BOT_CPUS=0.50
STREAM_BOT_MEM_LIMIT=512m
STREAM_BOT_MEM_RESERVATION=256m
STREAM_BOT_PIDS_LIMIT=100

STREAM_AI_CPUS=0.50
STREAM_AI_MEM_LIMIT=512m
STREAM_AI_MEM_RESERVATION=256m
STREAM_AI_PIDS_LIMIT=100

STREAM_TTS_CPUS=1.00
STREAM_TTS_MEM_LIMIT=1536m
STREAM_TTS_MEM_RESERVATION=768m
STREAM_TTS_PIDS_LIMIT=200

# Зарезервировано для будущего RTMP/Chromium (сейчас не используются)
# STREAM_VISUAL_CPUS=0.75
# STREAM_VISUAL_MEM_LIMIT=1024m
# STREAM_RENDERER_CPUS=2.00
# STREAM_RENDERER_MEM_LIMIT=1536m

REDIS_CPUS=0.25
REDIS_MEM_LIMIT=128m
REDIS_MEM_RESERVATION=64m
REDIS_PIDS_LIMIT=100

# --- Docker Compose: лимиты low (2 vCPU / 4 GB VPS) ---
# Раскомментируйте блок ниже при RESOURCE_PROFILE=low
# STREAM_BOT_CPUS=0.15
# STREAM_BOT_MEM_LIMIT=128m
# STREAM_AI_CPUS=0.25
# STREAM_AI_MEM_LIMIT=256m
# STREAM_TTS_CPUS=0.75
# STREAM_TTS_MEM_LIMIT=1024m
# REDIS_CPUS=0.10
# REDIS_MEM_LIMIT=64m

# --- Redis (общий с CreativeTrace или локальный) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=1
REDIS_KEY_PREFIX=infinity_stream:

# Для Redis CreativeTrace на хосте:
# REDIS_HOST=host.docker.internal
# REDIS_PORT=6379
# REDIS_DB=2

# --- Twitch (секреты — заполните) ---
TWITCH_CHANNEL=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_BOT_ID=

# --- LLM / Gemini-compatible API (секреты — заполните) ---
# --- LLM (OpenRouter или F5AI) ---
# auto — OpenRouter, если задан OPENROUTER_API_KEY, иначе F5AI
LLM_PROVIDER=auto
OPENROUTER_API_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash-lite-preview-06-06:free

F5AI_API_URL=
F5AI_API_TOKEN=
F5AI_MODEL=

# --- AI limits ---
AI_MAX_CONTEXT_MESSAGES=15
AI_MAX_INPUT_CHARS=12000
# Монолог до ~1200 символов + строка «НОВАЯ ТЕМА» в начале ответа
AI_MAX_OUTPUT_TOKENS=1024
AI_MAX_CONCURRENCY=1
AI_QUEUE_MAX_SIZE=20
AI_REQUEST_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# --- Twitch chat limits ---
CHAT_MAX_MESSAGE_LENGTH=500
CHAT_RESPONSE_COOLDOWN_SECONDS=15
CHAT_USER_COOLDOWN_SECONDS=60
CHAT_MAX_EVENTS_PER_MINUTE=100
CHAT_TTS_PRE_PAUSE_SECONDS=2
CHAT_TTS_POST_PAUSE_SECONDS=2
CHAT_POLL_INTERVAL_SECONDS=0.2
# Пауза между монологами (должна покрывать длительность TTS)
MONOLOGUE_MIN_INTERVAL_SECONDS=90

# --- TTS ---
TTS_OUTPUT_MODE=speaker
TTS_OUTPUT_DIR=output/tts
TTS_SPEAKER=eugene
TTS_SAMPLE_RATE=48000
TTS_MAX_CONCURRENCY=1
TTS_QUEUE_MAX_SIZE=10
# 0 — без обрезки; Silero сам режет по TTS_CHUNK_MAX_LENGTH (лимит модели ~1000)
TTS_MAX_TEXT_LENGTH=0
TTS_CHUNK_MAX_LENGTH=990
TTS_MAX_CHUNKS=3
TTS_CHUNK_PAUSE_SECONDS=0.25
TTS_TIMEOUT_SECONDS=45
TTS_TEMP_MAX_AGE_MINUTES=30
TTS_TEMP_MAX_SIZE_MB=300

# --- FFmpeg / stream (RTMP пока не подключён) ---
STREAM_WIDTH=1280
STREAM_HEIGHT=720
STREAM_FPS=20
STREAM_VIDEO_BITRATE=3000k
STREAM_AUDIO_BITRATE=128k
STREAM_X264_PRESET=ultrafast

# При RESOURCE_PROFILE=low приложение подставит 15 FPS и 2500k, если не переопределено

# --- Visual (React fractal, run_visual.py) ---
VISUAL_HOST=127.0.0.1
VISUAL_PORT=8765
# OBS Browser Source → http://127.0.0.1:8765
VISUAL_TARGET_FPS=30
VISUAL_COMPLEXITY=low
VISUAL_VOLUME_SMOOTHING=0.18
# demo — автономно; wav — реакция на WAV из TTS_OUTPUT_DIR
VISUAL_MODE=demo
VISUAL_PLAY_AUDIO=1

# --- Disk / logging ---
MIN_FREE_DISK_GB=10
LOG_LEVEL=INFO

# --- Health / metrics ---
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8080
# Разные порты для локальных процессов в run_local_supervisor (избегает конфликта 8080)
# LOCAL_HEALTH_PORT_STREAMER=8080
# LOCAL_HEALTH_PORT_PODCASTER=8081
# LOCAL_HEALTH_PORT_CHAT_READER=8082
HEARTBEAT_TIMEOUT_MINUTES=5

STREAMER_POLL_INTERVAL=1.0

# --- Telegram control bot ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
# Прокси для api.telegram.org (v2rayN: socks5://127.0.0.1:10808, Clash: http://127.0.0.1:7890)
# TELEGRAM_PROXY=socks5://127.0.0.1:10808
# TELEGRAM_AUTO_PROXY=1
# TELEGRAM_TOPIC_POLL_INTERVAL=2.0
# Redis с хоста для run_streamer.py / run_local_supervisor.py / локального TG-бота
LOCAL_REDIS_HOST=localhost
# Supervisor поднимает Docker-контейнеры chat_reader + podcaster по флагу стрима
LOCAL_SUPERVISOR_MANAGE_DOCKER=1
# chat_reader локально (supervisor + TG /start_stream); Docker-бот не стартует
LOCAL_CHAT_READER=1
# podcaster локально (supervisor); Docker-ai не стартует (по умолчанию 1 в run_local_supervisor)
LOCAL_PODCASTER=1
# Автостарт пайплайна (streamer/podcaster) при запуске supervisor
LOCAL_SUPERVISOR_AUTO_START=1
# Запускать run_visual.py вместе со стримом (OBS: Browser Source → VISUAL_URL)
# VISUAL_ENABLED=1

# --- OBS WebSocket (OBS 28+: Tools → WebSocket Server Settings) ---
# OBS_ENABLED=1
# OBS_WEBSOCKET_HOST=127.0.0.1
# OBS_WEBSOCKET_PORT=4455
# OBS_WEBSOCKET_PASSWORD=
# Вариант A: hotkey (Settings → Hotkeys в OBS, имя как в списке)
# OBS_HOTKEY_NAME=My Overlay Hotkey
# Вариант B: переключить сцену (опционально вернуть OBS_SCENE_RETURN_TO через N сек)
# OBS_SCENE_NAME=Alert
# OBS_SCENE_RETURN_TO=Main
# OBS_SIGNAL_DURATION=2.5
# OBS_SIGNAL_COMMANDS=set_topic,start_stream,stop_stream
# OBS_AUTO_START_STREAM=1  — StartStream в OBS при /start_stream и LOCAL_SUPERVISOR_AUTO_START
# OBS_AUTO_STOP_STREAM=1   — StopStream при /stop_stream и остановке supervisor

# --- Compose profiles ---
# TG + Redis + bot + AI (streamer локально):
# COMPOSE_PROFILES=local-redis,app,control
#
# Только приложение (внешний Redis CreativeTrace):
# COMPOSE_PROFILES=app

# --- Telegram control bot (локально, run_telegram_bot.py) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USER_IDS=123456789
# PROJECT_DIR=C:\path\to\InfinityAIStream
# AUTO_START_PLAYER=true
# STREAM_BUILD_ON_START=false
